import math

print("=== EINSTEIN TIME DILATION CALCULATOR ===")
print("Formula: t = t0 / sqrt(1 - v^2/c^2)")
print("")

# Speed of light = 300,000 km/s
c = 300000 

# You input the spaceship speed
v = float(input("Enter spaceship speed in km/s: "))

# Safety check: speed can't be >= speed of light
if v >= c:
    print("Error: Speed cannot be equal to or greater than the speed of light (300,000 km/s)")
else:
    # Time dilation formula
    t0 = 1 # 1 year on Earth
    t = t0 / math.sqrt(1 - (v**2 / c**2))

    print(f"")
    print(f"If you travel at {v} km/s for 1 year on the spaceship")
    print(f"{t:.2f} years will pass on Earth")
    print(f"So you will be {t-1:.2f} years younger than your friends on Earth!")